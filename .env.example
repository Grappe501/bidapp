# =============================================================================
# Local / Neon Postgres — copy to `.env` and fill in real values (never commit `.env`)
# =============================================================================
# Neon: Dashboard → Connection → copy full URI with real password (not masked).
# Keep sslmode=require. If Neon appends channel_binding=require, you can include it
# when your client supports it; otherwise sslmode=require alone is common.

DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD_HERE@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# Server + Netlify functions (embed, parse, drafts, etc.) — never expose via Vite
OPENAI_API_KEY=

# Optional model overrides (defaults work for most setups)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_PARSE_MODEL=gpt-4o-mini

# Frontend → Netlify functions. Use http://localhost:8888 with `netlify dev`, or your deploy URL.
VITE_FUNCTIONS_BASE_URL=http://localhost:8888

# Default project for DB-backed UI (URL ingest, optional list-projects filtering).
# After `npm run db:seed`, the S000000479 project id is deterministic for this repo:
VITE_DEFAULT_PROJECT_ID=c4dcdda2-5902-45f4-b937-2647809c3a19
# Or set from DB: SELECT id, bid_number FROM projects;

# CORS: browser origin allowed to call functions (dev vs prod).
ALLOWED_ORIGIN=http://localhost:8888

# Shared secret: Netlify functions reject requests without matching header.
# Set the same value in VITE_INTERNAL_API_KEY when using strict mode (below).
INTERNAL_API_KEY=

# When true, functions hide db-health, enforce stricter behavior (see netlify/functions/db-health.ts).
STRICT_DB_MODE=false

# Production-style: require INTERNAL_API_KEY on the client too (must match server).
# VITE_STRICT_DB_MODE=true
# VITE_INTERNAL_API_KEY=same_as_INTERNAL_API_KEY

# Optional: local Postgres without SSL only
# PGSSLMODE=disable
