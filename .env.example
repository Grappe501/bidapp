# Neon / Postgres (connection string from Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: disable SSL for local Postgres only
# PGSSLMODE=disable

# Frontend → Netlify functions (e.g. http://localhost:8888 when using `netlify dev`)
# Leave empty when not running functions; app falls back to in-memory state.
VITE_FUNCTIONS_BASE_URL=

# Optional: default project UUID for URL ingest (from DB after seed — list-projects)
VITE_DEFAULT_PROJECT_ID=

# OpenAI (Netlify functions / server jobs — never expose in Vite)
OPENAI_API_KEY=
# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_PARSE_MODEL=gpt-4o-mini
