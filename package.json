{
  "name": "bid-assembly",
  "private": true,
  "version": "0.12.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:print-project-id": "tsx scripts/print-seed-project-id.ts",
    "ingest:price-sheet": "tsx scripts/ingest-s479-price-sheet.ts",
    "ingest:technical-proposal-packet": "tsx scripts/ingest-s479-technical-proposal-packet.ts",
    "ingest:contract-grant-disclosure": "tsx scripts/ingest-s479-contract-grant-disclosure.ts",
    "check:openai": "tsx scripts/check-openai-api-key.ts",
    "setup:openai-key": "tsx scripts/setup-openai-env-key.ts",
    "extract:rfp-pdf": "tsx scripts/extract-rfp-pdf-text.ts",
    "check:server-aliases": "tsx scripts/check-server-aliases.ts",
    "check:private-deploy-env": "tsx scripts/check-private-deploy-env.ts",
    "check:netlify-prod-env": "tsx scripts/check-netlify-prod-env.ts",
    "typecheck:server": "tsc -p tsconfig.server.json && npm run check:server-aliases",
    "lift:db": "npm run db:migrate && npm run db:seed",
    "lift:verify": "npm run check:private-deploy-env && npm run lint && npm run typecheck:server && npm run build",
    "lift": "npm run lift:db && npm run lift:verify",
    "netlify:build": "npx --yes netlify-cli build"
  },
  "dependencies": {
    "@netlify/functions": "^3.0.4",
    "cheerio": "^1.2.0",
    "mammoth": "^1.12.0",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3"
  }
}
