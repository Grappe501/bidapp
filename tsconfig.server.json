{
  "compilerOptions": {
    // `src/server` and `netlify/functions` must use relative imports into `src/*`
    // (see scripts/check-server-aliases.ts). `@/*` stays here so TypeScript can still
    // resolve shared `src/lib` modules that import other files via `@/…`.
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["src/server/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/server/**/*.ts",
    "src/lib/allcare-branding-next-actions.ts",
    "netlify/functions/**/*.ts",
    "scripts/**/*.ts"
  ]
}
