{
  "compilerOptions": {
    // `src/server` and `netlify/functions` must use relative imports into `src/*`
    // (see scripts/check-server-aliases.ts). `@/*` stays here so TypeScript can still
    // resolve shared `src/lib` modules that import other files via `@/…`.
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["src/server/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/server/**/*.ts",
    "src/lib/allcare-branding-next-actions.ts",
    "src/lib/rfp-narrative.ts",
    "src/lib/contract-narrative.ts",
    "src/lib/contract-rfp-crosscheck.ts",
    "src/lib/contract-readiness.ts",
    "src/lib/contract-pricing-validation.ts",
    "src/lib/pricing-structure.ts",
    "src/data/canonical-pricing-s000000479.ts",
    "src/data/pricing-proposal-language-mapping.ts",
    "src/data/canonical-solution-section-s000000479.ts",
    "src/data/canonical-risk-section-s000000479.ts",
    "src/data/canonical-interview-section-s000000479.ts",
    "src/data/canonical-executive-summary-s000000479.ts",
    "src/types/pricing-model.ts",
    "src/data/canonical-rfp-s000000479.ts",
    "src/data/canonical-srv1-contract.ts",
    "src/types/rfp-model.ts",
    "src/types/contract-model.ts",
    "netlify/functions/**/*.ts",
    "scripts/**/*.ts"
  ]
}
